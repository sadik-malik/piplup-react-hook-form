{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "module": "esnext",
    "moduleResolution": "bundler",
    "rootDir": "./src",
    "exactOptionalPropertyTypes": false,
    "esModuleInterop": true,
    "types": ["node", "vite/client"]
  },
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*.spec.js",
    "src/**/*.spec.jsx"
  ],
  "include": ["src/**/*.js", "src/**/*.jsx", "src/**/*.ts", "src/**/*.tsx"]
}
