{
  "name": "@piplup/rhf-adapters",
  "version": "4.5.0",
  "private": false,
  "description": "A library designed to streamline the integration of react-hook-form with UI frameworks by managing boilerplate code.",
  "keywords": [
    "react-hook-form",
    "react-hook-form @mui/base",
    "react-hook-form @mui/material",
    "react-hook-form @mui/x-date-pickers",
    "react-hook-form adapters",
    "react-hook-form material",
    "react-hook-form mui"
  ],
  "homepage": "https://www.piplupjs.com",
  "license": "MIT",
  "repository": {
    "url": "git+https://github.com/sadik-malik/piplup-react-hook-form.git",
    "directory": "packages/rhf-adapters"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./html": {
      "types": "./dist/html/index.d.ts",
      "import": "./dist/html.mjs",
      "require": "./dist/html.js"
    },
    "./mui-lab": {
      "types": "./dist/mui-lab/index.d.ts",
      "import": "./dist/mui-lab.mjs",
      "require": "./dist/mui-lab.js"
    },
    "./mui-material": {
      "types": "./dist/mui-material/index.d.ts",
      "import": "./dist/mui-material.mjs",
      "require": "./dist/mui-material.js"
    },
    "./mui-x-date-pickers": {
      "types": "./dist/mui-x-date-pickers/index.d.ts",
      "import": "./dist/mui-x-date-pickers.mjs",
      "require": "./dist/mui-x-date-pickers.js"
    },
    "./mui-chips-input": {
      "types": "./dist/mui-chips-input/index.d.ts",
      "import": "./dist/mui-chips-input.mjs",
      "require": "./dist/mui-chips-input.js"
    },
    "./mui-color-input": {
      "types": "./dist/mui-color-input/index.d.ts",
      "import": "./dist/mui-color-input.mjs",
      "require": "./dist/mui-color-input.js"
    },
    "./mui-file-input": {
      "types": "./dist/mui-file-input/index.d.ts",
      "import": "./dist/mui-file-input.mjs",
      "require": "./dist/mui-file-input.js"
    },
    "./mui-one-time-password-input": {
      "types": "./dist/mui-one-time-password-input/index.d.ts",
      "import": "./dist/mui-one-time-password-input.mjs",
      "require": "./dist/mui-one-time-password-input.js"
    },
    "./mui-tel-input": {
      "types": "./dist/mui-tel-input/index.d.ts",
      "import": "./dist/mui-tel-input.mjs",
      "require": "./dist/mui-tel-input.js"
    },
    "./react-number-format": {
      "types": "./dist/react-number-format/index.d.ts",
      "import": "./dist/react-number-format.mjs",
      "require": "./dist/react-number-format.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest"
  },
  "devDependencies": {
    "@mui/material": "^9.0.1",
    "@mui/x-date-pickers": "^9.1.0",
    "@piplup/rhf-core": "file:../rhf-core",
    "@piplup/utils": "^3.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.6",
    "dayjs": "^1.11.20",
    "mui-chips-input": "^9.0.0",
    "mui-color-input": "^9.0.0",
    "mui-file-input": "^9.0.0",
    "mui-one-time-password-input": "^7.0.0",
    "mui-tel-input": "^11.0.0",
    "playwright": "^1.60.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.75.0",
    "react-number-format": "^5.4.5",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.6",
    "vitest-browser-commands": "^0.2.0",
    "vitest-browser-react": "^2.2.0"
  },
  "peerDependencies": {
    "@mui/material": ">=6.0.0 <10.0.0",
    "@mui/x-date-pickers": ">=9.0.0 <10.0.0",
    "@piplup/rhf-core": "^4.5.0",
    "@piplup/utils": "3.2.4",
    "mui-chips-input": ">=4.0.1 <10.0.0",
    "mui-color-input": ">=5.0.1 <10.0.0",
    "mui-file-input": ">=6.0.0 <10.0.0",
    "mui-one-time-password-input": ">=5.0.0 <8.0.0",
    "mui-tel-input": "^7.0.0 <12.0.0",
    "react": "^19.0.0",
    "react-hook-form": ">=7.65.0 <8.0.0",
    "react-number-format": ">=5.4.2 <6.0.0"
  },
  "peerDependenciesMeta": {
